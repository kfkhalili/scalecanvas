# Copy to .env.local and fill in (do not commit .env.local)
# All AWS/Bedrock vars are SERVER-ONLY — never use NEXT_PUBLIC_ for them.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SECRET_KEY=

# OAuth (used by Supabase Auth: local = config.toml env(); hosted = Dashboard → Providers)
# For local: ensure these are in env when running `supabase start` (e.g. source .env.local).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# BFF /api/chat (Bedrock) — server-only, never expose to client
# Create an IAM user with bedrock:InvokeModel + bedrock:InvokeModelWithResponseStream, then create an access key.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Use an inference profile ID (required for Claude Sonnet 4.6 on-demand).
# Example: global.anthropic.claude-sonnet-4-6 (cross-region; use from us-east-1, us-west-2, etc.)
# See AWS Bedrock docs: inference profiles → Supported cross-Region inference profiles.
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6

# Stripe — server-only, never expose to client
# Create products and prices in your Stripe Dashboard; use Checkout Sessions API.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_5=
STRIPE_PRICE_ID_15=
STRIPE_PRICE_ID_50=
